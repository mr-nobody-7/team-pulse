DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
NODE_ENV=development
PORT=4000
JWT_SECRET=your_jwt_secret_key
CLIENT_URL=http://localhost:3000
# Optional: comma-separated allowlist for multiple frontends
# CLIENT_URLS=https://team-pulse-web-omega.vercel.app,https://your-custom-domain.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Google OAuth callback URL:
# - Local: http://localhost:5000/api/auth/google/callback
# - Production: https://your-render-url.onrender.com/api/auth/google/callback
# This exact production URL must also be added in Google Cloud Console:
# OAuth 2.0 -> Authorised redirect URIs
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Team Pulse
TEAM_MIN_CAPACITY_WARNING_PERCENT=50